{
  "plugin": "org.smartide.plugin.springboot",
  "run": "./mvnw spring-boot:run",
  "intelligence": {
    ".json": {
      "enabled": true,
      "run": "vscode-json-language-server --stdio"
    },
    ".java": {
      "enabled": true,
      "run": "jdtls"
    },
    ".properties": {
      "enabled": true,
      "run": "lemminx"
    },
    ".xml": {
      "enabled": true,
      "run": "lemminx"
    },
    ".html": {
      "enabled": true,
      "run": "vscode-html-language-server --stdio"
    },
    ".css": {
      "enabled": true,
      "run": "vscode-css-language-server --stdio"
    },
    ".js": {
      "enabled": true,
      "run": "typescript-language-server --stdio"
    }
  }
}